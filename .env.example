# Apify credentials — copy this file to .env and fill in your values
# Get your token from https://console.apify.com/settings/integrations

# Used by scripts/fetch-jobs.js (Node.js, runs at build time / locally)
APIFY_TOKEN=apify_api_your_token_here
APIFY_ACTOR_ID=fantastic-jobs~career-site-job-listing-api

# Used by src/api.js during `npm run dev` only (Vite injects these into the browser bundle)
# NEVER used in production builds — the browser loads jobs.json instead
VITE_APIFY_TOKEN=apify_api_your_token_here
VITE_APIFY_ACTOR_ID=fantastic-jobs~career-site-job-listing-api
